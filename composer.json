{
    "name": "aisdk/google",
    "description": "Official Google Gemini provider for the PHP AI SDK.",
    "license": "MIT",
    "keywords": [
        "ai",
        "aisdk",
        "gemini",
        "google",
        "llm"
    ],
    "homepage": "https://github.com/phpaisdk/google",
    "support": {
        "issues": "https://github.com/phpaisdk/google/issues",
        "source": "https://github.com/phpaisdk/google"
    },
    "require": {
        "php": "^8.3",
        "aisdk/core": "^0.5"
    },
    "require-dev": {
        "laravel/pint": "^1.18",
        "nyholm/psr7": "^1.8",
        "pestphp/pest": "^3.0 || ^4.0",
        "phpstan/phpstan": "^2.0",
        "rector/rector": "^2.0"
    },
    "minimum-stability": "alpha",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "AiSdk\\": "src/Root/",
            "AiSdk\\Google\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AiSdk\\Google\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "lint": "vendor/bin/pint --test",
        "format": "vendor/bin/pint",
        "analyze": "vendor/bin/phpstan analyze --memory-limit=512M",
        "refactor:dry": "vendor/bin/rector process --dry-run",
        "refactor": "vendor/bin/rector process",
        "test": "vendor/bin/pest",
        "test:all": [
            "@lint",
            "@analyze",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    }
}
